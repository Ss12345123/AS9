# Gold AI Platform - System Configuration Template
# Copy this file to .env and fill in your actual credentials.

# System & Host Config
NODE_ENV=development
PORT=3000
APP_URL=
APP_SECRET=
CORS_ORIGIN=*
CORS_CREDENTIALS=true
SESSION_TIMEOUT=3600000

# Security & Encryption
ENCRYPTION_KEY=
ENCRYPTION_IV=
JWT_SECRET=
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@goldai.com
ADMIN_PASSCODE=1234

# Gemini AI Integration
GEMINI_API_KEY=

# Twelve Data Integration (Market Data)
TWELVE_DATA_API_KEY=

# Capital.com Integration (Broker)
CAPITAL_COM_DEMO=true
CAPITAL_COM_API_URL=https://demo-api-capital.backend-capital.com
CAPITAL_COM_API_KEY=
CAPITAL_COM_IDENTIFIER=
CAPITAL_COM_PASSWORD=

# Google OAuth Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend Mail Integration
RESEND_API_KEY=

# Telegram Bot Integration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Feature Flags & Simulation Defaults
DEBUG_MODE=true
ENABLE_DEMO_MODE=true
ENABLE_LIVE_TRADING=false
ENABLE_MOCK_DATA=true
ENABLE_PAPER_TRADING=true
CACHE_DURATION=900

# Logging & Monitoring
LOG_LEVEL=info
LOG_FILE=logs/app.log
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# Database Configuration
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=
DATABASE_USER=
DATABASE_NAME=
DATABASE_PASSWORD=
